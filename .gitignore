# ============================================================
# GeoSurvey PBB - .gitignore
# ============================================================

# ── Environment & Secrets ────────────────────────────────────
**/.env
**/.env.*
!**/.env.example

# ── Node.js / Backend ────────────────────────────────────────
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Flutter / Dart ───────────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/build/
/coverage/

# ── Android ──────────────────────────────────────────────────
**/android/app/debug
**/android/app/profile
**/android/app/release
*.apk
*.aab
local.properties
**/.gradle/
**/android/.cxx/

# ── iOS / macOS ──────────────────────────────────────────────
**/ios/Pods/
**/ios/.symlinks/
**/macos/Pods/
**/*.xcworkspace

# ── IDE ──────────────────────────────────────────────────────
*.iml
*.ipr
*.iws
.idea/
.vscode/
*.swp
*.swo

# ── OS Generated ────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Miscellaneous ────────────────────────────────────────────
*.class
*.log
*.pyc
.atom/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# ── Symbolication / Obfuscation ─────────────────────────────
app.*.symbols
app.*.map.json

# ── Docker (jangan commit data volume) ──────────────────────
db_data/
