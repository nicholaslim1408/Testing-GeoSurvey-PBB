# ============================================================
# GeoSurvey PBB - Environment Variables Template
# Copy file ini menjadi .env dan isi nilainya
# cp .env.example .env
# ============================================================

# Server
PORT=3000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=              # <-- Isi password MySQL kamu
DB_NAME=geosurvey_pbb

# JWT (gunakan random string minimal 64 karakter)
JWT_SECRET=               # <-- Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=7d
